# ExoMonad - track config and source, ignore runtime artifacts
.exo/*
!.exo/config.toml
!.exo/roles/
!.exo/lib/
!.exo/rules/
**/.exo/

# Claude / Gemini tooling
.claude/
.gemini/

# MCP config (may contain secrets)
.mcp.json

# Bun
node_modules/
bun.lockb

# Build output
dist/
.vite/

# Database files
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.db

# OS
.DS_Store
